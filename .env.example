# ============================================
# Production Environment Configuration
# ============================================
# Copy this file to .env and fill in the values

# ============================================
# Database Configuration (Required)
# ============================================
DATABASE_URL="file:./dev.db"
# For production: DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ============================================
# Authentication (Required)
# ============================================
# JWT secret for token signing - MUST be a strong random string
# Generate with: openssl rand -base64 32
JWT_SECRET="your-secure-jwt-secret-here"

# NextAuth secret for session encryption
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"

# ============================================
# Application URL (Required in production)
# ============================================
# The public URL of your application (no trailing slash)
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ============================================
# Email Configuration (Optional)
# ============================================
# Required for email verification and password reset
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="your-email@gmail.com"

# ============================================
# Firebase Configuration (Optional)
# ============================================
# Required for Google sign-in via Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""

# ============================================
# Google OAuth (Optional - Alternative to Firebase)
# ============================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# Feature Flags (Optional)
# ============================================
NEXT_PUBLIC_ENABLE_REGISTRATION="true"
NEXT_PUBLIC_ENABLE_GOOGLE_LOGIN="true"

# ============================================
# Security Configuration (Optional)
# ============================================
# Trusted proxy count (set to 1 if behind a single proxy)
TRUSTED_PROXY_COUNT="0"

# ============================================
# Analytics (Optional)
# ============================================
NEXT_PUBLIC_GA_ID=""
