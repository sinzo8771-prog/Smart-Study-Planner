# Database (Required)
DATABASE_URL="postgresql://user:password@host:6543/database"
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/database"

# Authentication (Required)
JWT_SECRET="your-secure-jwt-secret-here-min-32-characters"
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email Configuration (Optional - for future email features)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="your-email@gmail.com"

# Feature Flags
NEXT_PUBLIC_ENABLE_REGISTRATION="true"
USE_STATIC_DATA="false"

# Proxy Configuration (for production behind CDN/proxy)
TRUSTED_PROXY_COUNT="0"

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=""
