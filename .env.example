# ============================================
# Production Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# For Vercel deployment, set these in your Vercel project settings

# ============================================
# Database Configuration (Required for Production)
# ============================================
# For Vercel, use a PostgreSQL database like Supabase, Neon, or Vercel Postgres
# Example Supabase connection string:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
# DIRECT_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# For connection pooling (recommended for serverless):
# DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

DATABASE_URL=""
DIRECT_DATABASE_URL=""

# ============================================
# Authentication (Required)
# ============================================
# JWT secret for token signing - MUST be a strong random string
# Generate with: openssl rand -base64 32
JWT_SECRET="your-secure-jwt-secret-here"

# NextAuth secret for session encryption
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"

# ============================================
# Application URL (Required in production)
# ============================================
# The public URL of your application (no trailing slash)
# For Vercel: https://your-project-name.vercel.app
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ============================================
# Email Configuration (Optional)
# ============================================
# Required for email verification and password reset
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="your-email@gmail.com"

# ============================================
# Firebase Configuration (Optional)
# ============================================
# Required for Google sign-in via Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# ============================================
# Google OAuth (Optional - Alternative to Firebase)
# ============================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# Feature Flags (Optional)
# ============================================
NEXT_PUBLIC_ENABLE_REGISTRATION="true"
NEXT_PUBLIC_ENABLE_GOOGLE_LOGIN="true"

# ============================================
# Static Data Mode (Optional)
# ============================================
# Set to 'true' to use static data instead of database
# Useful for demo deployments without a database
USE_STATIC_DATA="false"

# ============================================
# Security Configuration (Optional)
# ============================================
# Trusted proxy count (set to 1 if behind a single proxy)
TRUSTED_PROXY_COUNT="0"

# ============================================
# Analytics (Optional)
# ============================================
NEXT_PUBLIC_GA_ID=""
